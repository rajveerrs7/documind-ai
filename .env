# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

# ─────────────────────────────────────────────────────────────
# DocuMind AI — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase PostgreSQL with pgvector) ─────────────
# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://postgres.hyhavyenfoqqiinepaqo:bVIznhKMAtG3l9h1@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://postgres.hyhavyenfoqqiinepaqo:bVIznhKMAtG3l9h1@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# ── Groq API (Free Tier LLM - llama3-8b-8192) ───────────────
# Get your key at: https://console.groq.com/
GROQ_API_KEY="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"

# ── HuggingFace Inference API (Free Tier Embeddings) ────────
# Get your key at: https://huggingface.co/settings/tokens
# Model used: BAAI/bge-small-en-v1.5
HUGGINGFACEHUB_API_KEY="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"

# ── JWT Authentication ───────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-minimum-32-chars-long"
JWT_EXPIRES_IN="7d"

# ── Redis / Upstash (Rate Limiting + Caching) ────────────────
# Get your credentials at: https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://comic-snipe-71727.upstash.io"
UPSTASH_REDIS_REST_TOKEN="gQAAAAAAARgvAAIgcDFlNDk1ZjdiYWEwYTI0OGVmYjEzNjE2MGZmOTNmNjE0ZA"

# ── App Configuration ────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_NAME="DocuMind AI"

# ── File Upload Configuration ────────────────────────────────
# Max file size in bytes (10MB default)
MAX_FILE_SIZE_BYTES=10485760

# ── Usage Limits (Free Tier) ─────────────────────────────────
# Monthly token limit per user
FREE_TIER_MONTHLY_TOKEN_LIMIT=50000

# ── LangChain / Vector Store Configuration ──────────────────
# Table name used by LangChain's PGVector store
VECTOR_STORE_TABLE_NAME="document_embeddings"

# Number of similar chunks to retrieve per query
RETRIEVER_TOP_K=4

# ── Admin Configuration ──────────────────────────────────────
# The email address that gets ADMIN role on first registration
ADMIN_EMAIL="rajveer.rs2005@gmail.com"

# ── Node Environment ─────────────────────────────────────────
NODE_ENV="development"