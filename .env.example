# ─────────────────────────────────────────────────────────────
# DocuMind AI — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase PostgreSQL with pgvector) ─────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://postgres:password@db.yourproject.supabase.co:5432/postgres?sslmode=require"

# Direct connection URL for Prisma migrations (bypasses PgBouncer)
DIRECT_URL="postgresql://postgres:password@db.yourproject.supabase.co:5432/postgres?sslmode=require"

# ── Groq API (Free Tier LLM - llama3-8b-8192) ───────────────
# Get your key at: https://console.groq.com/
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── HuggingFace Inference API (Free Tier Embeddings) ────────
# Get your key at: https://huggingface.co/settings/tokens
# Model used: BAAI/bge-small-en-v1.5
HUGGINGFACEHUB_API_KEY="hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── JWT Authentication ───────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-minimum-32-chars-long"
JWT_EXPIRES_IN="7d"

# ── Redis / Upstash (Rate Limiting + Caching) ────────────────
# Get your credentials at: https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── App Configuration ────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_NAME="DocuMind AI"

# ── File Upload Configuration ────────────────────────────────
# Max file size in bytes (10MB default)
MAX_FILE_SIZE_BYTES=10485760

# ── Usage Limits (Free Tier) ─────────────────────────────────
# Monthly token limit per user
FREE_TIER_MONTHLY_TOKEN_LIMIT=50000

# ── LangChain / Vector Store Configuration ──────────────────
# Table name used by LangChain's PGVector store
VECTOR_STORE_TABLE_NAME="document_embeddings"

# Number of similar chunks to retrieve per query
RETRIEVER_TOP_K=4

# ── Admin Configuration ──────────────────────────────────────
# The email address that gets ADMIN role on first registration
ADMIN_EMAIL="admin@yourdomain.com"

# ── Node Environment ─────────────────────────────────────────
NODE_ENV="development"